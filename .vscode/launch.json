{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: Debug (TSX)",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/apps/zhp-accounts-backend",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx"
      ],
      "args": [
        "src/main.ts"
      ],
      "env": {
        "NODE_ENV": "development",
        "PORT": "3000",
        "LOG_LEVEL": "debug",
        "MOCK_AUDIT": "true",
        "MOCK_ENTRA": "true",
        "MOCK_TIPI": "true",

        "MOCK_MAIL": "true",
        "MAIL_ACS_ENDPOINT": "https://acs-konto-dev.europe.communication.azure.com",
        "MAIL_FROM_ADDRESS": "dev@konto.zhp.pl"
      },
      "skipFiles": [
        "<node_internals>/**"
      ],
      "console": "integratedTerminal"
    }
  ]
}
