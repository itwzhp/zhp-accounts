{
  "name": "zhp-accounts-backend",
  "version": "1.0.0",
  "description": "ZHP Accounts Backend API - Node 24 LTS TypeScript",
  "type": "module",
  "main": "dist/main.cjs",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "build:bundle": "tsup --config tsup.config.ts",
    "build": "pnpm run typecheck && pnpm run build:bundle",
    "start": "node dist/main.cjs",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage"
  },
  "dependencies": {
    "@azure/communication-email": "^1.1.0",
    "@azure/identity": "^4.13.1",
    "@microsoft/microsoft-graph-client": "^3.0.7",
    "express": "^4.21.1",
    "jose": "^6.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/microsoft-graph-types": "^2.40.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "@typescript-eslint/parser": "^7.16.1",
    "@vitest/ui": "^2.0.5",
    "eslint": "^9.9.1",
    "tsc-alias": "^1.8.10",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.0.5",
    "zhp-accounts-types": "file:../zhp-accounts-types"
  }
}
